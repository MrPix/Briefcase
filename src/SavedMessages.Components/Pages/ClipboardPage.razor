@page "/clipboard"
@page "/favorites"
@page "/files"
@page "/links"
@page "/text"
@namespace SavedMessages.Components.Pages
@inject IMessageService MessageService
@inject IClipboardService ClipboardService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div class="clipboard-drop-zone @(_isDragOver ? "drag-over" : "")"
     @ondragenter="HandleDragEnter"
     @ondragenter:preventDefault
     @ondragleave="HandleDragLeave"
     @ondragleave:preventDefault
     @ondragover:preventDefault
     @ondrop="HandleDrop"
     @ondrop:preventDefault>

    @if (_isDragOver)
    {
        <div class="drop-overlay">
            <div class="drop-overlay-content">
                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <p>Drop files here to upload</p>
            </div>
        </div>
    }

    <div class="clipboard-layout">
        @* ── Center: message list ── *@
        <div class="clipboard-list">


            @if (_isUploading)
            {
                <div class="upload-progress">
                    <span>Uploading...</span>
                </div>
            }

            <div class="filter-tabs">
                <button class="filter-tab @(_activeFilter == "all" ? "active" : "")" @onclick='() => SetFilter("all")'>All</button>
                <button class="filter-tab @(_activeFilter == "pinned" ? "active" : "")" @onclick='() => SetFilter("pinned")'>
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="filter-tab @(_activeFilter == "file" ? "active" : "")" @onclick='() => SetFilter("file")'>
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="filter-tab @(_activeFilter == "url" ? "active" : "")" @onclick='() => SetFilter("url")'>
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <button class="filter-tab @(_activeFilter == "text" ? "active" : "")" @onclick='() => SetFilter("text")'>
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h10M4 18h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="filter-spacer"></div>
                <button class="filter-tab" title="Sort">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 4h13M3 8h9M3 12h5m0 0l4 4m-4-4l4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
            </div>

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger mx-3" role="alert">
                    @_errorMessage
                    <button class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadMessages">Retry</button>
                </div>
            }
            else if (_messages is null)
            {
                <div class="loading-state">
                    <p>Loading messages...</p>
                </div>
            }
            else if (_filteredMessages.Count == 0)
            {
                <div class="empty-state">
                    <svg width="48" height="48" fill="none" stroke="var(--text-muted)" stroke-width="1" viewBox="0 0 24 24"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <p>No messages yet</p>
                    <span>Send your first message to get started</span>
                </div>
            }
            else
            {
                <div class="message-list">
                    @if (_pinnedMessages.Count > 0 && _activeFilter is "all" or "pinned")
                    {
                        <div class="list-section-header">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Pinned
                        </div>
                        @foreach (var message in _pinnedMessages)
                        {
                            <div class="message-item">
                                <SavedMessages.Components.Components.MessageCard
                                    Message="message"
                                    OnPin="HandlePin"
                                    OnDelete="HandleDelete"
                                    OnCopy="HandleCopy"
                                    OnDownload="HandleDownload" />
                            </div>
                        }
                    }

                    @if (_recentMessages.Count > 0 && _activeFilter != "pinned")
                    {
                        <div class="list-section-header">Today</div>
                        @foreach (var message in _recentMessages)
                        {
                            <div class="message-item">
                                <SavedMessages.Components.Components.MessageCard
                                    Message="message"
                                    OnPin="HandlePin"
                                    OnDelete="HandleDelete"
                                    OnCopy="HandleCopy"
                                    OnDownload="HandleDownload" />
                            </div>
                        }
                    }
                </div>
            }

            <div class="compose-area">
                    @if (_stagedFiles.Count > 0)
                    {
                        <div class="staged-files">
                            @foreach (var file in _stagedFiles)
                            {
                                <div class="staged-file">
                                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    <span class="staged-file-name">@file.Name</span>
                                    <span class="staged-file-size">@FormatFileSize(file.Size)</span>
                                    <button class="staged-file-remove" @onclick="() => RemoveStagedFile(file)" title="Remove">
                                        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </button>
                                </div>
                            }
                            <label class="staged-file-add" title="Add more files">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
                                Add files
                                <InputFile OnChange="HandleFileSelected" style="display:none" multiple />
                            </label>
                        </div>
                    }
                    <textarea class="compose-input" @bind="_newContent" placeholder="@(_stagedFiles.Count > 0 ? "Add a comment (optional)..." : "Type or paste a message...")" rows="3"></textarea>
                    <div class="compose-actions">
                        @if (_stagedFiles.Count == 0)
                        {
                            <label class="toolbar-btn" title="Attach file">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                <InputFile OnChange="HandleFileSelected" style="display:none" multiple />
                            </label>
                        }
                        <button class="toolbar-btn" @onclick="PasteFromClipboard" title="Paste from clipboard">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>
                        <button class="toolbar-btn primary" @onclick="SendMessage" disabled="@(!CanSend)">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            Send
                        </button>
                    </div>
                </div>
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<Message>? _messages;
    private List<Message> _pinnedMessages = new();
    private List<Message> _recentMessages = new();
    private List<Message> _filteredMessages = new();
    private string? _newContent;
    private string? _searchQuery;
    private string _activeFilter = "all";
    private bool _isDragOver;
    private string? _errorMessage;
    private bool _isUploading;
    private List<StagedFile> _stagedFiles = new();

    private bool CanSend => _stagedFiles.Count > 0 || !string.IsNullOrWhiteSpace(_newContent);

    private record StagedFile(string Name, string ContentType, long Size, byte[] Data);

    protected override async Task OnInitializedAsync()
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath.TrimStart('/').ToLowerInvariant();
        _activeFilter = path switch
        {
            "favorites" => "pinned",
            "files" => "file",
            "links" => "url",
            "text" => "text",
            _ => "all"
        };
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        try
        {
            _errorMessage = null;
            _messages = await MessageService.GetMessagesAsync();
        }
        catch (Exception ex)
        {
            _messages = [];
            _errorMessage = $"Failed to load messages: {ex.Message}";
        }

        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var filtered = _messages?.AsEnumerable() ?? [];

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            filtered = filtered.Where(m => m.Content?.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) == true);
        }

        filtered = _activeFilter switch
        {
            "pinned" => filtered.Where(m => m.IsPinned),
            "file" => filtered.Where(m => m.Kind == MessageKind.File),
            "url" => filtered.Where(m => m.Kind == MessageKind.Url),
            "text" => filtered.Where(m => m.Kind == MessageKind.Text),
            _ => filtered
        };

        _filteredMessages = filtered.ToList();
        _pinnedMessages = _filteredMessages.Where(m => m.IsPinned).ToList();
        _recentMessages = _filteredMessages.Where(m => !m.IsPinned).ToList();
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        ApplyFilters();
    }


    private async Task SendMessage()
    {
        if (!CanSend)
            return;

        try
        {
            if (_stagedFiles.Count > 0)
            {
                _isUploading = true;
                StateHasChanged();

                var comment = string.IsNullOrWhiteSpace(_newContent) ? null : _newContent;
                foreach (var file in _stagedFiles)
                {
                    using var stream = new MemoryStream(file.Data);
                    await MessageService.UploadFileAsync(file.Name, file.ContentType, stream, comment);
                    comment = null; // only attach comment to the first file
                }
            }
            else
            {
                var kind = Uri.TryCreate(_newContent, UriKind.Absolute, out var uri)
                    && (uri.Scheme == "http" || uri.Scheme == "https")
                    ? MessageKind.Url
                    : MessageKind.Text;

                await MessageService.CreateMessageAsync(kind, _newContent!);
            }

            _newContent = null;
            _stagedFiles.Clear();
            await LoadMessages();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to send message: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task PasteFromClipboard()
    {
        var text = await ClipboardService.GetTextAsync();
        if (text is not null)
        {
            _newContent = text;
        }
    }

    private async Task HandlePin(Message message)
    {
        await MessageService.TogglePinAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleDelete(Message message)
    {
        await MessageService.DeleteMessageAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleCopy(Message message)
    {
        if (message.Content is not null)
        {
            await ClipboardService.SetTextAsync(message.Content);
        }
    }

    private async Task HandleDownload(Message message)
    {
        if (message.FileId is not null)
        {
            try
            {
                var (data, contentType, fileName) = await MessageService.DownloadFileAsync(message.FileId.Value);
                await JS.InvokeVoidAsync("SavedMessages.downloadFile", fileName, contentType, data);
            }
            catch (Exception ex)
            {
                _errorMessage = $"Failed to download file: {ex.Message}";
            }
        }
    }

    private void HandleDragEnter(DragEventArgs e)
    {
        _isDragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private void HandleDrop(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _stagedFiles.Add(new StagedFile(file.Name, file.ContentType, file.Size, ms.ToArray()));
        }
    }

    private void RemoveStagedFile(StagedFile file)
    {
        _stagedFiles.Remove(file);
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
