@page "/clipboard"
@namespace SavedMessages.Components.Pages
@inject IMessageService MessageService
@inject IClipboardService ClipboardService

<h1>Clipboard</h1>

<div class="clipboard-drop-zone @(_isDragOver ? "drag-over" : "")"
     @ondragenter="HandleDragEnter"
     @ondragenter:preventDefault
     @ondragleave="HandleDragLeave"
     @ondragleave:preventDefault
     @ondragover:preventDefault
     @ondrop="HandleDrop"
     @ondrop:preventDefault>

    @if (_isDragOver)
    {
        <div class="drop-overlay">
            <div class="drop-overlay-content">
                <span class="bi bi-cloud-upload" style="font-size: 3rem;"></span>
                <p>Drop files here to upload</p>
            </div>
        </div>
    }

<div class="clipboard-layout">
    <div class="clipboard-list">
        <div class="mb-3">
            <div class="input-group">
                <textarea class="form-control" @bind="_newContent" placeholder="Type or paste a message..." rows="3"></textarea>
                <button class="btn btn-primary" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(_newContent)">
                    <span class="bi bi-send"></span> Send
                </button>
            </div>
        </div>

        <div class="mb-3">
            <button class="btn btn-outline-secondary" @onclick="PasteFromClipboard">
                <span class="bi bi-clipboard"></span> Paste from clipboard
            </button>
        </div>

        @if (_errorMessage is not null)
        {
            <div class="alert alert-danger" role="alert">
                @_errorMessage
                <button class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadMessages">Retry</button>
            </div>
        }
        else if (_messages is null)
        {
            <p><em>Loading messages...</em></p>
        }
        else if (_messages.Count == 0)
        {
            <p class="text-muted">No messages yet. Send your first message above!</p>
        }
        else
        {
            @if (_pinnedMessages.Count > 0)
            {
                <h6 class="text-muted">Pinned</h6>
                @foreach (var message in _pinnedMessages)
                {
                    <div class="@(_selectedMessage?.Id == message.Id ? "selected-message" : "")" @onclick="() => SelectMessage(message)">
                        <SavedMessages.Components.Components.MessageCard
                            Message="message"
                            OnPin="HandlePin"
                            OnDelete="HandleDelete"
                            OnCopy="HandleCopy" />
                    </div>
                }
            }

            @if (_recentMessages.Count > 0)
            {
                <h6 class="text-muted">Recent</h6>
                @foreach (var message in _recentMessages)
                {
                    <div class="@(_selectedMessage?.Id == message.Id ? "selected-message" : "")" @onclick="() => SelectMessage(message)">
                        <SavedMessages.Components.Components.MessageCard
                            Message="message"
                            OnPin="HandlePin"
                            OnDelete="HandleDelete"
                            OnCopy="HandleCopy" />
                    </div>
                }
            }
        }
    </div>

    <div class="clipboard-detail">
        @if (_selectedMessage is not null)
        {
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Message Detail</strong>
                    <small class="text-muted">@_selectedMessage.CreatedAt.ToString("f")</small>
                </div>
                <div class="card-body">
                    @if (_selectedMessage.Kind == MessageKind.Url)
                    {
                        <a href="@_selectedMessage.Content" target="_blank" rel="noopener noreferrer">@_selectedMessage.Content</a>
                    }
                    else if (_selectedMessage.Kind == MessageKind.File)
                    {
                        <span class="bi bi-file-earmark"></span>
                        <span>File attachment</span>
                    }
                    else
                    {
                        <p class="card-text">@_selectedMessage.Content</p>
                    }
                </div>
                <div class="card-footer">
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary" @onclick="() => HandleCopy(_selectedMessage)">
                            <span class="bi bi-clipboard"></span> Copy
                        </button>
                        <button class="btn btn-outline-warning" @onclick="() => HandlePin(_selectedMessage)">
                            <span class="bi @(_selectedMessage.IsPinned ? "bi-pin-fill" : "bi-pin")"></span>
                            @(_selectedMessage.IsPinned ? "Unpin" : "Pin")
                        </button>
                        <button class="btn btn-outline-danger" @onclick="() => HandleDelete(_selectedMessage)">
                            <span class="bi bi-trash"></span> Delete
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-muted text-center mt-5">
                <p>Select a message to view details</p>
            </div>
        }
    </div>
</div>
</div>

@code {
    private IReadOnlyList<Message>? _messages;
    private List<Message> _pinnedMessages = new();
    private List<Message> _recentMessages = new();
    private Message? _selectedMessage;
    private string? _newContent;
    private bool _isDragOver;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        try
        {
            _errorMessage = null;
            _messages = await MessageService.GetMessagesAsync();
        }
        catch (Exception ex)
        {
            _messages = [];
            _errorMessage = $"Failed to load messages: {ex.Message}";
        }

        _pinnedMessages = _messages?.Where(m => m.IsPinned).ToList() ?? new();
        _recentMessages = _messages?.Where(m => !m.IsPinned).ToList() ?? new();

        if (_selectedMessage is not null && _messages is not null)
        {
            _selectedMessage = _messages.FirstOrDefault(m => m.Id == _selectedMessage.Id);
        }
    }

    private void SelectMessage(Message message)
    {
        _selectedMessage = message;
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newContent))
            return;

        try
        {
            var kind = Uri.TryCreate(_newContent, UriKind.Absolute, out var uri)
                && (uri.Scheme == "http" || uri.Scheme == "https")
                ? MessageKind.Url
                : MessageKind.Text;

            await MessageService.CreateMessageAsync(kind, _newContent);
            _newContent = null;
            await LoadMessages();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to send message: {ex.Message}";
        }
    }

    private async Task PasteFromClipboard()
    {
        var text = await ClipboardService.GetTextAsync();
        if (text is not null)
        {
            _newContent = text;
        }
    }

    private async Task HandlePin(Message message)
    {
        await MessageService.TogglePinAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleDelete(Message message)
    {
        await MessageService.DeleteMessageAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleCopy(Message message)
    {
        if (message.Content is not null)
        {
            await ClipboardService.SetTextAsync(message.Content);
        }
    }

    private void HandleDragEnter(DragEventArgs e)
    {
        _isDragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private void HandleDrop(DragEventArgs e)
    {
        _isDragOver = false;
    }
}
