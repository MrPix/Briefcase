@page "/clipboard"
@namespace SavedMessages.Components.Pages
@inject IMessageService MessageService
@inject IClipboardService ClipboardService

<h1>Clipboard</h1>

<div class="mb-3">
    <div class="input-group">
        <textarea class="form-control" @bind="_newContent" placeholder="Type or paste a message..." rows="3"></textarea>
        <button class="btn btn-primary" @onclick="SendMessage" disabled="@string.IsNullOrWhiteSpace(_newContent)">
            <span class="bi bi-send"></span> Send
        </button>
    </div>
</div>

<div class="mb-3">
    <button class="btn btn-outline-secondary" @onclick="PasteFromClipboard">
        <span class="bi bi-clipboard"></span> Paste from clipboard
    </button>
</div>

@if (_messages is null)
{
    <p><em>Loading messages...</em></p>
}
else if (_messages.Count == 0)
{
    <p class="text-muted">No messages yet. Send your first message above!</p>
}
else
{
    @foreach (var message in _messages)
    {
        <SavedMessages.Components.Components.MessageCard
            Message="message"
            OnPin="HandlePin"
            OnDelete="HandleDelete"
            OnCopy="HandleCopy" />
    }
}

@code {
    private IReadOnlyList<Message>? _messages;
    private string? _newContent;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        _messages = await MessageService.GetMessagesAsync();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newContent))
            return;

        var kind = Uri.TryCreate(_newContent, UriKind.Absolute, out var uri)
            && (uri.Scheme == "http" || uri.Scheme == "https")
            ? MessageKind.Url
            : MessageKind.Text;

        await MessageService.CreateMessageAsync(kind, _newContent);
        _newContent = null;
        await LoadMessages();
    }

    private async Task PasteFromClipboard()
    {
        var text = await ClipboardService.GetTextAsync();
        if (text is not null)
        {
            _newContent = text;
        }
    }

    private async Task HandlePin(Message message)
    {
        await MessageService.TogglePinAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleDelete(Message message)
    {
        await MessageService.DeleteMessageAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleCopy(Message message)
    {
        if (message.Content is not null)
        {
            await ClipboardService.SetTextAsync(message.Content);
        }
    }
}
