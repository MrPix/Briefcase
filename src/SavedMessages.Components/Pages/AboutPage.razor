@page "/about"
@namespace SavedMessages.Components.Pages

<div class="about-container">
    <div class="about-card">
        <div class="about-header">
            <svg width="48" height="48" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="28" height="28" rx="8" fill="#6C3FC5"/>
                <path d="M8 10h12M8 14h8M8 18h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <h2 class="about-title">SavedMessages</h2>
            <span class="about-version">Version 1.0.0</span>
        </div>

        <div class="about-section">
            <h5>About</h5>
            <p>
                SavedMessages is a cross-platform app for securely saving, syncing, and transferring
                messages across your devices with end-to-end encryption.
            </p>
        </div>

        <div class="about-section">
            <h5>Features</h5>
            <ul class="about-features">
                <li>End-to-end encrypted message storage</li>
                <li>Cross-device sync and QR transfer</li>
                <li>Support for text, links, and file attachments</li>
                <li>Favorites and trash management</li>
            </ul>
        </div>

        <div class="about-section">
            <h5>Links</h5>
            <ul class="list-unstyled about-links">
                <li>
                    <a href="https://github.com/MrPix/SavedMessages" target="_blank" rel="noopener noreferrer">
                        GitHub Repository
                    </a>
                </li>
            </ul>
        </div>
    </div>
</div>
