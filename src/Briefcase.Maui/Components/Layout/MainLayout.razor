@inherits LayoutComponentBase
@inject IServiceProvider ServiceProvider
@inject Briefcase.Components.Services.IAuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

@{
    var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
    var isAuthPage = uri.StartsWith("login", StringComparison.OrdinalIgnoreCase)
                  || uri.StartsWith("signup", StringComparison.OrdinalIgnoreCase);
}

@if (isAuthPage || AuthService.IsAuthenticated)
{
    @if (isAuthPage)
    {
        <main class="auth-main">
            @Body
        </main>
    }
    else
    {
        <div class="page">
            <header class="top-bar">
                <div class="top-bar-inner">
                    <div class="top-bar-brand">
                        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <defs>
                                <linearGradient id="brandGradient" x1="2" y1="2" x2="26" y2="26" gradientUnits="userSpaceOnUse">
                                    <stop offset="0" stop-color="#22C55E" />
                                    <stop offset="1" stop-color="#0EA5E9" />
                                </linearGradient>
                            </defs>
                            <rect width="28" height="28" rx="8" fill="url(#brandGradient)" />
                            <path
                            d="M9 6.5V20.9M9 6.5H13.9C16.9 6.5 18.8 8.3 18.8 10.8C18.8 13.2 16.9 15 13.9 15H9M9 15H14.5C17.7 15 19.6 16.9 19.6 19.3C19.6 21.8 17.7 23.5 14.5 23.5H9"
                            stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                            <rect x="15.6" y="12.3" width="3.1" height="3.1" rx="0.95" fill="#F59E0B"
                                  transform="rotate(12 17.15 13.85)" />
                        </svg>
                        <span class="top-bar-title">Briefcase</span>
                    </div>
                </div>
            </header>

            <main>
                @Body
            </main>

            <NavMenu />
        </div>
    }
}

@code {
    private Briefcase.Components.Services.IThemeService? _themeService;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            try
            {
                await AuthService.TryRestoreSessionAsync();
            }
            catch
            {
                // Keep UI alive even if auth backend is unavailable.
            }
        }

        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var isAuthPage = uri.StartsWith("login", StringComparison.OrdinalIgnoreCase)
                      || uri.StartsWith("signup", StringComparison.OrdinalIgnoreCase);

        if (!isAuthPage && !AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _themeService = ServiceProvider.GetService<Briefcase.Components.Services.IThemeService>();
            if (_themeService is not null)
            {
                await _themeService.ApplyThemeAsync();
                _themeService.ThemeChanged += OnThemeChanged;
            }
        }
    }

    private void OnThemeChanged(string theme)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_themeService is not null)
        {
            _themeService.ThemeChanged -= OnThemeChanged;
        }
    }
}
