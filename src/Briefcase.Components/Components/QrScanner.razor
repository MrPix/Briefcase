@namespace Briefcase.Components.Components
@inject IQrScannerService QrScannerService

<div class="qr-scanner">
    @if (!QrScannerService.IsSupported)
    {
        <div class="alert alert-warning">QR scanning is not supported on this platform.</div>
    }
    else if (_isScanning)
    {
        <div class="d-flex flex-column align-items-center">
            <div class="spinner-border text-primary mb-2" role="status">
                <span class="visually-hidden">Scanning...</span>
            </div>
            <p>Point your camera at a QR code</p>
            <button class="btn btn-secondary" @onclick="CancelScan">Cancel</button>
        </div>
    }
    else
    {
        <button class="btn btn-primary" @onclick="StartScan">
            <span class="bi bi-qr-code-scan"></span> Scan QR Code
        </button>
    }

    @if (_lastResult is not null)
    {
        <div class="alert alert-success mt-2">Scanned: @_lastResult</div>
    }
</div>

@code {
    private bool _isScanning;
    private string? _lastResult;
    private CancellationTokenSource? _cts;

    [Parameter]
    public EventCallback<string> OnScanned { get; set; }

    private async Task StartScan()
    {
        _isScanning = true;
        _cts = new CancellationTokenSource();

        try
        {
            var result = await QrScannerService.ScanAsync();
            if (result is not null)
            {
                _lastResult = result;
                await OnScanned.InvokeAsync(result);
            }
        }
        finally
        {
            _isScanning = false;
            _cts = null;
        }
    }

    private void CancelScan()
    {
        _cts?.Cancel();
        _isScanning = false;
    }
}
