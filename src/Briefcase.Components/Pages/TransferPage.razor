@page "/transfer"
@namespace Briefcase.Components.Pages
@inject ITransferService TransferService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

@if (_isSendMode)
{
    @* ── Send mode: authenticated device sends a message by entering the code ── *@
    <div class="transfer-container">
        <div class="transfer-card">
            <div class="transfer-icon send">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h2 class="transfer-title">Send Message</h2>
            <p class="transfer-subtitle">Enter the 8-character code shown on the receiving device.</p>

            @if (!_sent)
            {
                <div class="code-input-group">
                    <input class="code-input" type="text" maxlength="8" placeholder="ABCD1234" @bind="_enteredCode"
                           @bind:event="oninput" autocomplete="off" spellcheck="false" />
                </div>

                @if (_errorMessage is not null)
                {
                    <div class="transfer-error">@_errorMessage</div>
                }

                <button class="transfer-btn primary" @onclick="HandleSend" disabled="@(_sending || _enteredCode.Length != 8)">
                    @if (_sending)
                    {
                        <span class="spinner"></span>
                        <span>Sending…</span>
                    }
                    else
                    {
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>Send</span>
                    }
                </button>
            }
            else
            {
                <div class="transfer-success">
                    <svg width="32" height="32" fill="none" stroke="#22c55e" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <p>Message sent! The recipient can now open the link on their device.</p>
                </div>
                <button class="transfer-btn secondary" @onclick='() => NavigationManager.NavigateTo("/clipboard")'>
                    Back to Clipboard
                </button>
            }
        </div>
    </div>
}
else
{
    @* ── Receive mode: unauthorized device shows an 8-char code and waits ── *@
    <div class="transfer-container">
        <div class="transfer-card">
            <div class="transfer-icon receive">
                <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke-linecap="round"
                          stroke-linejoin="round" />
                </svg>
            </div>
            <h2 class="transfer-title">Receive Message</h2>
            <p class="transfer-subtitle">Share this code with the sender. It expires in 10 minutes.</p>

            @if (_code is null)
            {
                <div class="transfer-loading">
                    <span class="spinner"></span>
                    <span>Generating code…</span>
                </div>
            }
            else if (_received)
            {
                <div class="transfer-success">
                    <svg width="32" height="32" fill="none" stroke="#22c55e" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <p>Message received! Opening…</p>
                </div>
            }
            else
            {
                <div class="code-display-group">
                    <span class="code-half">@_code[..4]</span>
                    <span class="code-separator">–</span>
                    <span class="code-half">@_code[4..]</span>
                </div>

                <div class="transfer-waiting">
                    <span class="pulse-dot"></span>
                    <span>Waiting for sender…</span>
                </div>
            }
            <button class="transfer-btn secondary" @onclick='() => NavigationManager.NavigateTo("/")'>
                Back
            </button>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public Guid? MessageId { get; set; }

    private bool _isSendMode;
    private string? _code;
    private bool _received;
    private string _enteredCode = string.Empty;
    private bool _sending;
    private bool _sent;
    private string? _errorMessage;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _isSendMode = MessageId.HasValue;

        if (!_isSendMode)
        {
            _code = await TransferService.CreateSessionAsync();
            _cts = new CancellationTokenSource();
            _ = StartListeningAsync(_cts.Token);
        }
    }

    private async Task StartListeningAsync(CancellationToken ct)
    {
        try
        {
            await TransferService.ListenForTransferAsync(_code!, async url =>
            {
                await InvokeAsync(() =>
                {
                    _received = true;
                    StateHasChanged();
                    NavigationManager.NavigateTo(url);
                });
            }, ct);
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task HandleSend()
    {
        _errorMessage = null;
        _sending = true;

        try
        {
            var code = _enteredCode.Trim().ToUpperInvariant();
            await TransferService.SendToAsync(code, MessageId!.Value);
            _sent = true;
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 404)
        {
            _errorMessage = "Code not found or expired. Please check and try again.";
        }
        catch (Exception)
        {
            _errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            _sending = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}

