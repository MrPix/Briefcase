@page "/clipboard"
@page "/favorites"
@page "/files"
@page "/links"
@page "/text"
@namespace Briefcase.Components.Pages
@inject IMessageService MessageService
@inject IClipboardService ClipboardService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="clipboard-drop-zone @(_isDragOver ? "drag-over" : "")" @ondragenter="HandleDragEnter"
     @ondragenter:preventDefault @ondragleave="HandleDragLeave" @ondragleave:preventDefault @ondragover:preventDefault
     @ondrop="HandleDrop" @ondrop:preventDefault>

    @if (_isDragOver)
    {
        <div class="drop-overlay">
            <div class="drop-overlay-content">
                <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <p>Drop files here to upload</p>
            </div>
        </div>
    }

    <div class="clipboard-layout">
        @* ── Center: message list ── *@
        <div class="clipboard-list">


            @if (_isUploading)
            {
                <div class="upload-progress">
                    <span>Uploading...</span>
                </div>
            }

            @if (_errorMessage is not null)
            {
                <div class="alert alert-danger mx-3" role="alert">
                    @_errorMessage
                    <button class="btn btn-sm btn-outline-danger ms-2" @onclick="LoadMessages">Retry</button>
                </div>
            }
            else if (_messages is null)
            {
                <div class="loading-state">
                    <p>Loading messages...</p>
                </div>
            }
            else if (_filteredMessages.Count == 0)
            {
                <div class="empty-state">
                    <svg width="48" height="48" fill="none" stroke="var(--text-muted)" stroke-width="1" viewBox="0 0 24 24">
                        <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>
                    <p>No messages yet</p>
                    <span>Send your first message to get started</span>
                </div>
            }
            else
            {
                <div class="message-list" @ref="_messageListRef">
                    @if (_pinnedMessages.Count > 0 && _activeFilter is "all" or "pinned")
                    {
                        <div class="list-section-header">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" stroke-linecap="round"
                                      stroke-linejoin="round" />
                            </svg>
                            Pinned
                        </div>
                        @foreach (var message in _visiblePinnedMessages)
                        {
                            <div class="message-item">
                                <Briefcase.Components.Components.MessageCard Message="message" OnPin="HandlePin"
                                                                             OnDelete="HandleDelete" OnCopy="HandleCopy" OnDownload="HandleDownload" OnEdit="HandleEdit"
                                                                             OnSendTo="HandleSendTo" />
                            </div>
                        }
                        @if (_activeFilter == "all" && _pinnedMessages.Count > MaxPinnedInClipboard)
                        {
                            <a class="see-all-link" href="/favorites">See all @_pinnedMessages.Count pinned</a>
                        }
                    }

                    @if (_recentGroups.Count > 0 && _activeFilter != "pinned")
                    {
                        @foreach (var group in _recentGroups)
                        {
                            <div class="list-section-header">@group.Label</div>
                            @foreach (var message in group.Items)
                            {
                                <div class="message-item">
                                    <Briefcase.Components.Components.MessageCard Message="message" OnPin="HandlePin"
                                                                                 OnDelete="HandleDelete" OnCopy="HandleCopy" OnDownload="HandleDownload" OnEdit="HandleEdit"
                                                                                 OnSendTo="HandleSendTo" />
                                </div>
                            }
                        }
                    }
                </div>
            }

            <div class="compose-area">
                @if (_stagedFiles.Count > 0)
                {
                    <div class="staged-files">
                        @foreach (var file in _stagedFiles)
                        {
                            <div class="staged-file">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                                     viewBox="0 0 24 24">
                                    <path
                                    d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                                    stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <span class="staged-file-name">@file.Name</span>
                                <span class="staged-file-size">@FormatFileSize(file.Size)</span>
                                <button class="staged-file-remove" @onclick="() => RemoveStagedFile(file)" title="Remove">
                                    <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"
                                         viewBox="0 0 24 24">
                                        <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </button>
                            </div>
                        }
                        <label class="staged-file-add" title="Add more files">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24">
                                <path d="M12 5v14M5 12h14" stroke-linecap="round" />
                            </svg>
                            Add files
                            <InputFile OnChange="HandleFileSelected" style="display:none" multiple />
                        </label>
                    </div>
                }
                <textarea class="compose-input" @bind="_newContent"
                          placeholder="@(_stagedFiles.Count > 0 ? "Add a comment (optional)..." : "Type or paste a message...")"
                          rows="3"></textarea>
                <div class="compose-actions">
                    @if (_stagedFiles.Count == 0)
                    {
                        <label class="toolbar-btn" title="Attach file">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                                 viewBox="0 0 24 24">
                                <path
                                d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"
                                stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <InputFile OnChange="HandleFileSelected" style="display:none" multiple />
                        </label>
                    }
                    <button class="toolbar-btn" @onclick="PasteFromClipboard" title="Paste from clipboard">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                             viewBox="0 0 24 24">
                            <path
                            d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                            stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button class="toolbar-btn primary" @onclick="SendMessage" disabled="@(!CanSend)">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                             viewBox="0 0 24 24">
                            <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                        Send
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private const int MaxPinnedInClipboard = 3;

    private ElementReference _messageListRef;
    private bool _shouldScrollToBottom;

    private IReadOnlyList<Message>? _messages;
    private List<Message> _pinnedMessages = new();
    private List<(string Label, List<Message> Items)> _recentGroups = new();
    private List<Message> _filteredMessages = new();

    private IEnumerable<Message> _visiblePinnedMessages =>
        _activeFilter == "all" ? _pinnedMessages.Take(MaxPinnedInClipboard) : _pinnedMessages;
    private string? _newContent;
    private string _activeFilter = "all";
    private bool _isDragOver;
    private string? _errorMessage;
    private bool _isUploading;
    private List<StagedFile> _stagedFiles = new();

    private bool CanSend => _stagedFiles.Count > 0 || !string.IsNullOrWhiteSpace(_newContent);

    private record StagedFile(string Name, string ContentType, long Size, byte[] Data);

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateFilterFromUrl();
        await LoadMessages();
    }

    private void UpdateFilterFromUrl()
    {
        var path = new Uri(NavigationManager.Uri).AbsolutePath.TrimStart('/').ToLowerInvariant();
        _activeFilter = path switch
        {
            "favorites" => "pinned",
            "files" => "file",
            "links" => "url",
            "text" => "text",
            _ => "all"
        };
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateFilterFromUrl();
        ApplyFilters();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScrollToBottom)
        {
            _shouldScrollToBottom = false;
            try { await JS.InvokeVoidAsync("Briefcase.scrollToBottom", _messageListRef); } catch { }
        }
    }

    private async Task LoadMessages()
    {
        try
        {
            _errorMessage = null;
            _messages = await MessageService.GetMessagesAsync();
        }
        catch (Exception ex)
        {
            _messages = [];
            _errorMessage = $"Failed to load messages: {ex.Message}";
        }

        ApplyFilters();
        _shouldScrollToBottom = true;
    }

    private void ApplyFilters()
    {
        var filtered = _messages?.AsEnumerable() ?? [];

        filtered = _activeFilter switch
        {
            "pinned" => filtered.Where(m => m.IsPinned),
            "file" => filtered.Where(m => m.Kind == MessageKind.File),
            "url" => filtered.Where(m => m.Kind == MessageKind.Url),
            "text" => filtered.Where(m => m.Kind == MessageKind.Text),
            _ => filtered
        };

        _filteredMessages = filtered.ToList();
        _pinnedMessages = _filteredMessages
            .Where(m => m.IsPinned)
            .OrderByDescending(m => m.PinnedAt)
            .ToList();

        var unpinned = _activeFilter is "all" or "pinned"
            ? _filteredMessages.Where(m => !m.IsPinned)
            : _filteredMessages.AsEnumerable();

        var today = DateTime.Today;
        _recentGroups = unpinned
            .GroupBy(m => GetDateLabel(m.CreatedAt, today))
            .OrderBy(g => g.Max(m => m.CreatedAt))
            .Select(g => (g.Key, g.OrderBy(m => m.CreatedAt).ToList()))
            .ToList();
    }

    private static string GetDateLabel(DateTime createdAt, DateTime today)
    {
        var date = createdAt.Date;
        if (date == today) return "Today";
        if (date == today.AddDays(-1)) return "Yesterday";
        if (date >= today.AddDays(-6)) return date.ToString("dddd");
        if (date.Year == today.Year) return date.ToString("MMMM d");
        return date.ToString("MMMM d, yyyy");
    }

    private void SetFilter(string filter)
    {
        _activeFilter = filter;
        ApplyFilters();
    }


    private async Task SendMessage()
    {
        if (!CanSend)
            return;

        try
        {
            if (_stagedFiles.Count > 0)
            {
                _isUploading = true;
                StateHasChanged();

                var comment = string.IsNullOrWhiteSpace(_newContent) ? null : _newContent;
                foreach (var file in _stagedFiles)
                {
                    using var stream = new MemoryStream(file.Data);
                    await MessageService.UploadFileAsync(file.Name, file.ContentType, stream, comment);
                    comment = null; // only attach comment to the first file
                }
            }
            else
            {
                var kind = Uri.TryCreate(_newContent, UriKind.Absolute, out var uri)
                    && (uri.Scheme == "http" || uri.Scheme == "https")
                    ? MessageKind.Url
                    : MessageKind.Text;

                await MessageService.CreateMessageAsync(kind, _newContent!);
            }

            _newContent = null;
            _stagedFiles.Clear();
            await LoadMessages();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to send message: {ex.Message}";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private async Task PasteFromClipboard()
    {
        var text = await ClipboardService.GetTextAsync();
        if (text is not null)
        {
            _newContent = text;
        }
    }

    private async Task HandlePin(Message message)
    {
        await MessageService.TogglePinAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleDelete(Message message)
    {
        await MessageService.DeleteMessageAsync(message.Id);
        await LoadMessages();
    }

    private async Task HandleCopy(Message message)
    {
        if (message.Content is not null)
        {
            await ClipboardService.SetTextAsync(message.Content);
        }
    }

    private async Task HandleDownload(Message message)
    {
        if (message.FileId is not null)
        {
            try
            {
                var (data, contentType, fileName) = await MessageService.DownloadFileAsync(message.FileId.Value);
                await JS.InvokeVoidAsync("Briefcase.downloadFile", fileName, contentType, data);
            }
            catch (Exception ex)
            {
                _errorMessage = $"Failed to download file: {ex.Message}";
            }
        }
    }

    private async Task HandleEdit(Message message)
    {
        try
        {
            await MessageService.EditMessageAsync(message.Id, message.Content);
            await LoadMessages();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to edit message: {ex.Message}";
        }
    }

    private void HandleSendTo(Message message)
    {
        NavigationManager.NavigateTo($"/transfer?messageId={message.Id}");
    }

    private void HandleDragEnter(DragEventArgs e)
    {
        _isDragOver = true;
    }

    private void HandleDragLeave(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private void HandleDrop(DragEventArgs e)
    {
        _isDragOver = false;
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(10))
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _stagedFiles.Add(new StagedFile(file.Name, file.ContentType, file.Size, ms.ToArray()));
        }
    }

    private void RemoveStagedFile(StagedFile file)
    {
        _stagedFiles.Remove(file);
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024.0:F1} KB";
        }

        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
