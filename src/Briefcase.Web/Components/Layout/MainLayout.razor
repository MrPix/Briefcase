@inherits LayoutComponentBase
@inject IServiceProvider ServiceProvider
@inject Briefcase.Components.Services.IAuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

@{
    var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
    var isLandingPage = uri == "";
    var isAuthPage = !isLandingPage
                  && (uri.StartsWith("login", StringComparison.OrdinalIgnoreCase)
                   || uri.StartsWith("signup", StringComparison.OrdinalIgnoreCase));
    var isTransferPage = uri.StartsWith("transfer", StringComparison.OrdinalIgnoreCase);
    var isSharePage = uri.StartsWith("share", StringComparison.OrdinalIgnoreCase);
    var isPublicPage = isLandingPage || isAuthPage || isTransferPage || isSharePage;
}

@if (!_sessionRestored)
{
    <p>Loading...</p>
}
else if (isPublicPage || AuthService.IsAuthenticated)
{
    @if (isLandingPage)
    {
        <main class="landing-main">
            @Body
        </main>
    }
    else if (isAuthPage || isTransferPage || isSharePage)
    {
        <main class="auth-main">
            @Body
        </main>
    }
    else
    {
        <div class="page">
            <div class="sidebar">
                <NavMenu />
            </div>

            <main>
                @Body
            </main>
        </div>
    }
}

@code {
    private Briefcase.Components.Services.IThemeService? _themeService;
    private bool _sessionRestored;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _themeService = ServiceProvider.GetService<Briefcase.Components.Services.IThemeService>();
            if (_themeService is not null)
            {
                await _themeService.ApplyThemeAsync();
                _themeService.ThemeChanged += OnThemeChanged;
            }

            if (!AuthService.IsAuthenticated)
            {
                await AuthService.TryRestoreSessionAsync();
            }

            _sessionRestored = true;

            var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
            var isPublicPage = uri == ""
                            || uri.StartsWith("login", StringComparison.OrdinalIgnoreCase)
                            || uri.StartsWith("signup", StringComparison.OrdinalIgnoreCase)
                            || uri.StartsWith("transfer", StringComparison.OrdinalIgnoreCase)
                            || uri.StartsWith("share", StringComparison.OrdinalIgnoreCase);

            if (!isPublicPage && !AuthService.IsAuthenticated)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
            }

            StateHasChanged();
        }
    }

    private void OnThemeChanged(string theme)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_themeService is not null)
        {
            _themeService.ThemeChanged -= OnThemeChanged;
        }
    }
}
