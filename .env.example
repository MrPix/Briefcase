# ── Briefcase — environment variables ────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
# .env is listed in .gitignore so secrets are never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image tag ────────────────────────────────────────────────────────────────
# Pin to a specific SHA tag (e.g. sha-a1b2c3d) or leave as "latest"
IMAGE_TAG=latest

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=briefcase
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters long.
JWT_SECRET=change_me_use_a_strong_secret_min32chars!!
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=365

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET_NAME=briefcase

# ── Public URL ───────────────────────────────────────────────────────────────
# The URL users open in their browser. Used for CORS AllowedOrigins.
# Examples:
#   http://192.168.1.100       (LAN IP, HTTP)
#   https://briefcase.home     (custom DNS + HTTPS)
PUBLIC_WEB_URL=http://localhost
